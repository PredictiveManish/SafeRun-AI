# Sarvam AI (optional)
SARVAM_API_KEY=your_key_here

# Backend (optional)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Docker sandbox image name
SANDBOX_IMAGE=saferun-sandbox:latest

# Database path (default: sqlite:///./saferun.db)
DATABASE_URL=sqlite:///./saferun.db

# Policy file path (default: backend/policies/default_policy.yaml)
POLICY_FILE=backend/policies/default_policy.yaml