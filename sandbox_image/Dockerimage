# Sandbox image for SafeRun AI
FROM python:3.11-slim

# Create non-root user
RUN useradd -m -u 1000 -s /bin/bash sandbox

# Set working directory inside container
WORKDIR /sandbox

# Ensure script directory exists and is writable only if needed (policy controlled by mount)
RUN chown sandbox:sandbox /sandbox && chmod 755 /sandbox

# Switch to non-root user
USER sandbox

# Default command (overridden by executor)
CMD ["python", "-u", "/sandbox/script.py"]